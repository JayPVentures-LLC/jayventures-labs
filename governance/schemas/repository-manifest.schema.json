{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jaypventuresllc.com/schemas/repository-manifest.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "repository", "executionBoundary", "systemLayers"],
  "properties": {
    "schemaVersion": {"type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$"},
    "repository": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "owner", "fullName", "purpose", "productionStatus", "workflowOwner", "runtime", "lane", "phoneFirst"],
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "owner": {"type": "string", "minLength": 1},
        "fullName": {"type": "string", "pattern": "^[^/]+/[^/]+$"},
        "purpose": {"type": "string", "minLength": 1},
        "productionStatus": {"type": "string", "enum": ["production", "non-production"]},
        "workflowOwner": {"type": "string", "minLength": 1},
        "runtime": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
        "lane": {"type": "array", "minItems": 1, "items": {"type": "string", "enum": ["creator", "business", "labs", "operations"]}},
        "phoneFirst": {"type": "boolean"}
      }
    },
    "executionBoundary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scope", "nexusProductionSourceOfTruth", "nexusProductionRoutingAllowed", "statusFile"],
      "properties": {
        "scope": {"type": "string", "minLength": 1},
        "nexusProductionSourceOfTruth": {"type": "string", "pattern": "^[^/]+/[^/]+$"},
        "nexusProductionRoutingAllowed": {"type": "boolean"},
        "statusFile": {"type": "string", "minLength": 1}
      }
    },
    "systemLayers": {
      "type": "object",
      "additionalProperties": false,
      "required": ["trust", "entitlement", "revenueCommand", "publicReadinessGate", "operatorSafety", "lifecycleArchive", "relationshipMap", "offerEngine", "learningLoop", "proofOfWorkDashboard"],
      "properties": {
        "trust": {"type": "string", "enum": ["active", "planned"]},
        "entitlement": {"type": "string", "enum": ["active", "planned"]},
        "revenueCommand": {"type": "string", "enum": ["active", "planned"]},
        "publicReadinessGate": {"type": "string", "enum": ["active", "planned"]},
        "operatorSafety": {"type": "string", "enum": ["active", "planned"]},
        "lifecycleArchive": {"type": "string", "enum": ["active", "planned"]},
        "relationshipMap": {"type": "string", "enum": ["active", "planned"]},
        "offerEngine": {"type": "string", "enum": ["active", "planned"]},
        "learningLoop": {"type": "string", "enum": ["active", "planned"]},
        "proofOfWorkDashboard": {"type": "string", "enum": ["active", "planned"]}
      }
    }
  }
}
