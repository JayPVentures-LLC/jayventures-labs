{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jaypventuresllc.com/schemas/deployment-registry.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "generatedAtUtc", "repositories", "deployments"],
  "properties": {
    "schemaVersion": {"type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$"},
    "generatedAtUtc": {"type": "string", "format": "date-time"},
    "repositories": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["repository", "role", "owner"],
        "properties": {
          "repository": {"type": "string", "pattern": "^[^/]+/[^/]+$"},
          "role": {"type": "string", "minLength": 1},
          "owner": {"type": "string", "minLength": 1}
        }
      }
    },
    "deployments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "service", "deploymentSource", "deploymentTarget", "environment", "productionUrl", "workflow", "branch", "lastDeployment", "lastFailure", "rollbackTarget", "lane", "workflowOwner"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "service": {"type": "string", "minLength": 1},
          "deploymentSource": {"type": "string", "minLength": 1},
          "deploymentTarget": {"type": "string", "minLength": 1},
          "environment": {"type": "string", "enum": ["production", "staging", "development", "test"]},
          "productionUrl": {"type": "string", "pattern": "^https://"},
          "workflow": {"type": "string", "minLength": 1},
          "branch": {"type": "string", "minLength": 1},
          "lastDeployment": {"type": "string", "minLength": 1},
          "lastFailure": {"type": "string", "minLength": 1},
          "rollbackTarget": {"type": "string", "minLength": 1},
          "lane": {"type": "string", "enum": ["creator", "business", "labs", "operations"]},
          "workflowOwner": {"type": "string", "minLength": 1},
          "readOnlyReference": {"type": "boolean"}
        }
      }
    }
  }
}
