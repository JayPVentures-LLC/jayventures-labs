{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "WebWorker"],
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "types": ["vitest/globals", "@cloudflare/workers-types", "node"]
  },
  "include": [
    "operations/**/*.ts",
    "wix/**/*.ts",
    "tests/**/*.ts",
    "vitest.config.ts"
  ]
}
