# ============================================================
# JayPVentures Entitlement Worker — Multi-Cloud Dev Vars
# Copy to .dev.vars and fill in real values before running locally.
# NEVER commit .dev.vars — it is in .gitignore.
# Production values are set as Cloudflare Worker secrets via:
#   npx wrangler secret put <VAR_NAME> --config operations/entitlement-system/wrangler.toml
# ============================================================

# Shared / Internal
INTERNAL_SYNC_TOKEN="replace_me"
LOG_LEVEL="info"

# ---- Stripe (billing source of truth) ----------------------
STRIPE_WEBHOOK_SECRET="replace_me"
STRIPE_SECRET_KEY="replace_me"

# ---- Discord (role reflection) -----------------------------
DISCORD_BOT_TOKEN="replace_me"
DISCORD_BOT_TOKEN_SECRET_NAME="discord-bot-token"
DISCORD_GUILD_ID="replace_me"
DISCORD_ROLE_COMMUNITY_ID="replace_me"
DISCORD_ROLE_VIP_ID="replace_me"

# ---- Discord OAuth / activation flow -----------------------
OAUTH_STATE_SECRET="replace_me"
ACTIVATION_TOKEN_SECRET="replace_me"
PUBLIC_BASE_URL="https://jaypventuresllc.com"
DISCORD_OAUTH_REDIRECT_URI="https://jaypventuresllc.com/auth/discord/callback"
ENTITLEMENT_ACTIVATION_URL="https://jaypventuresllc.com/activate"

# ---- Admin --------------------------------------------------
ADMIN_OVERRIDE_KEY="replace_me"
ADMIN_OVERRIDE_KEY_SECRET_NAME="admin-override-key"

# ---- Azure Key Vault / App Insights / Archive ---------------
AZURE_KEY_VAULT_URL="https://replace-me.vault.azure.net"
AZURE_TENANT_ID="replace_me"
AZURE_CLIENT_ID="replace_me"
AZURE_CLIENT_SECRET="replace_me"
APPINSIGHTS_CONNECTION_STRING="InstrumentationKey=replace_me"
AZURE_ARCHIVE_ENDPOINT="https://replace-me.example/archive/entitlements"
AZURE_ARCHIVE_TOKEN="replace_me"
AZURE_ARCHIVE_TOKEN_SECRET_NAME="azure-archive-token"

# ---- Microsoft Teams / JayPVentures LLC ---------------------
MS_TENANT_ID="replace_me"
MS_CLIENT_ID="replace_me"
MS_CLIENT_SECRET="replace_me"
MS_TEAM_ID_LLC="replace_me"
MS_GROUP_ID_LLC_CLIENTS="replace_me"
MS_GROUP_ID_LLC_PARTNERS="replace_me"
MS_GROUP_ID_LLC_ENTERPRISE="replace_me"
