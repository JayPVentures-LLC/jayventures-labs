{
  "name": "jaypventures-labs",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:website": "vitest run tests/flagship-site.test.ts",
    "test:entitlement": "vitest run tests/entitlement-system.test.ts",
    "test:bookings": "vitest run tests/wix-bookings.test.ts",
    "typecheck": "tsc --noEmit",
    "jpv:enforce": "node ./scripts/jpv-enforce.mjs",
    "jpv:enforce:test": "node ./scripts/jpv-enforce.mjs --test",
    "enforce:brand": "ts-node operations/jpv_os_enforcement/cli.ts jaypventures_llc --file",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "dev:website": "wrangler dev --config apps/flagship-site/wrangler.toml",
    "dev:entitlement": "wrangler dev --config operations/entitlement-system/wrangler.toml",
    "dev:bookings": "wrangler dev --config wix/bookings/wrangler.toml",
    "deploy:dryrun:website": "wrangler deploy --dry-run --config apps/flagship-site/wrangler.toml",
    "deploy:dryrun:entitlement": "wrangler deploy --dry-run --config operations/entitlement-system/wrangler.toml",
    "deploy:dryrun:bookings": "wrangler deploy --dry-run --config wix/bookings/wrangler.toml",
    "stripe:audit": "node operations/stripe-audit.js",
    "lint": "eslint apps/ operations/ tests/ --ext .ts,.tsx,.js,.jsx,.mdx",
    "setup:devvars": "powershell -ExecutionPolicy Bypass -File scripts/setup-dev-vars.ps1",
    "validate:deploy:website": "node scripts/validate-deploy-config.mjs apps/flagship-site/wrangler.toml",
    "validate:deploy:entitlement": "node scripts/validate-deploy-config.mjs operations/entitlement-system/wrangler.toml",
    "validate:deploy:bookings": "node scripts/validate-deploy-config.mjs wix/bookings/wrangler.toml"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260504.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.6.0",
    "@types/react": "19.2.14",
    "@vitest/coverage-istanbul": "^3.1.2",
    "@vitest/ui": "^3.1.2",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2",
    "wrangler": "^4.11.1"
  },
  "dependencies": {
    "hono": "^4.12.16",
    "next": "^16.2.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "webpack": "^5.106.2"
  }
}
