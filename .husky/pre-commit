#!/bin/sh
. "$(dirname "$0")/_/husky.sh"

# Run enforcement CLI on all staged .md and .ts files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(md|ts)$' || true)
FAIL=0
for file in $STAGED_FILES; do
  if grep -qE '\.md$' <<< "$file"; then
    npx ts-node operations/jpv_os_enforcement/cli.ts jaypventures_llc "$(cat $file)" || FAIL=1
  fi
  if grep -qE '\.ts$' <<< "$file"; then
    npx ts-node operations/jpv_os_enforcement/cli.ts jaypventures_llc "$(cat $file)" || FAIL=1
  fi
  # Add more file types/brands as needed

done
if [ $FAIL -ne 0 ]; then
  echo "JPVOs enforcement failed. Commit aborted."
  exit 1
fi
